# ─────────────────────────────────────────────────────────────
# .env.example — copia in .env e inserisci le tue chiavi
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Locale (docker-compose): postgresql://footballhub:footballhub@postgres:5432/footballhub
# Cloud (Neon, ecc.):      postgresql://user:password@host/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/footballhub
REDIS_URL=redis://localhost:6379/0

# ── API Calcio ────────────────────────────────────────────────
# football-data.org — gratis, chiave immediata
FOOTBALL_DATA_API_KEY=
# rapidapi.com → "API-Football", piano free 100 req/giorno
API_FOOTBALL_KEY=
# the-odds-api.com — gratis, 500 req/mese
ODDS_API_KEY=

# ── Chatbot LLM ───────────────────────────────────────────────
# Priorità: Groq > OpenAI > Ollama locale
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

OPENAI_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Scraping ──────────────────────────────────────────────────
SCRAPER_DELAY=2.0
PROXY_URL=

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False
# Cambia questo valore in produzione: protegge gli endpoint /api/admin/*
SECRET_KEY=change-this-in-production
